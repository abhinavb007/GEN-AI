import gradio as gr
import os

# Assuming 'client' is already defined from previous cells (groq.Groq(api_key=os.environ["GROQ_API"]))

def respond(message, history, system_prompt, temperature):
  messages = []
  if system_prompt:
      messages.append({"role": "system", "content": system_prompt})

  # history contains tuples (user_message, assistant_message)
  for human_message, ai_message in history:
        messages.append({"role": "user", "content": human_message})
        messages.append({"role": "assistant", "content": ai_message})

  messages.append({"role": "user", "content": message})

  # Using a Groq client, assuming it's already defined and configured
  stream = client.chat.completions.create(
    model="llama-3.1-8b-instant", # Or any other Groq model you prefer
    messages=messages,
    temperature=temperature,
    stream=True,
  )
  
  partial_message = ""
  for chunk in stream:
    if chunk.choices[0].delta.content is not None:
      partial_message += chunk.choices[0].delta.content
      yield partial_message

# Define a default system prompt
default_system_prompt = '''You are a helpful AI assistant. Your goal is to provide concise and informative answers. If you don't know the answer, state that you don't know.'''

# Create the Gradio ChatInterface
demo = gr.ChatInterface(
    fn=respond,
    chatbot=gr.Chatbot(height=300, type="messages"),
    textbox=gr.Textbox(placeholder="Ask me a question!", container=False, scale=7),
    title="<center><h1>🤖 Customizable Chatbot (Groq)</h1></center>",
    description="Ask the AI anything! Adjust the system prompt and temperature to change its behavior.",
    theme="soft",
    examples=[
        ["What is the capital of France?", default_system_prompt, 0.7],
        ["Explain quantum computing in simple terms.", default_system_prompt, 0.5],
        ["Tell me a short story about a brave knight.", "You are a storyteller. Write creative and engaging stories.", 0.9]
    ],
    cache_examples=False,
    # Removed retry_btn, undo_btn, clear_btn as they cause TypeError with current Gradio version
    additional_inputs=[
        gr.Textbox(label="System Prompt", value=default_system_prompt, lines=3),
        gr.Slider(minimum=0, maximum=1, step=0.1, value=0.7, label="Temperature"),
    ],
)

# Launch the Gradio interface
demo.launch(debug=True)
